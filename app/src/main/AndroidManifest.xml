<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Обычное разрешение: календарным/будильниковым приложениям выдаётся
         автоматически при установке, без похода пользователя в настройки.
         Актуально при sideload — Google Play тут вообще не участвует. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Чтобы переставить будильники после перезагрузки устройства -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Начиная с Android 13 показ уведомлений требует разрешения,
         запрашиваемого в рантайме (см. MainActivity) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Полноэкранный попап поверх блокировки при срабатывании напоминания.
         На Android 14+ авто-выдаётся только через декларацию в Google Play,
         но это ограничение самого Play Store — при сайдлоаде не действует.
         Разрешение объявлено, а в коде дополнительно проверяем
         canUseFullScreenIntent() и аккуратно деградируем, если недоступно. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.SyncCalendar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".AlarmReceiver"
            android:exported="false" />

        <receiver
            android:name=".AlarmActionReceiver"
            android:exported="false" />

        <activity
            android:name=".ReminderAlarmActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.SyncCalendar" />

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
