<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/textReminder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/text"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/buttonSnoozeMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/surface2"
        android:textColor="@color/text"
        android:text="@string/snooze_pick" />

    <Button
        android:id="@+id/buttonSnooze5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/teal"
        android:textColor="@color/bg"
        android:text="@string/snooze_5min" />

    <Button
        android:id="@+id/buttonDismiss"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/amber"
        android:textColor="@color/bg"
        android:textStyle="bold"
        android:text="@string/dismiss" />

</LinearLayout>
